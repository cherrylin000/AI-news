# 复制为 .env 后填写（.env 不会提交到 Git）

# 站点（GitHub Pages）
SITE_URL=https://cherrylin000.github.io/AI-news

# follow.it 订阅表单：直接粘贴到根目录 index.html（dynamic-end 标记之后），无需环境变量

# SMTP（仅在使用 --legacy-smtp 时需要）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# LLM（生成洞察必填）— DeepSeek 示例（与 OpenAI 格式兼容）
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# 若用 OpenAI：
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o
