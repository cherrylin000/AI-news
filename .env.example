# 复制为 .env 后填写（.env 不会提交到 Git）

# 站点（GitHub Pages）
SITE_URL=https://cherrylin000.github.io/AI-news

# 邮件群发（Brevo SMTP 免费方案）
# GitHub Actions 中使用相同名称配置为 Repository secrets。
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=AI洞察日报
SMTP_REPLY_TO=

# 支持逗号/分号/换行分隔，也支持 "Name <email@example.com>"
NEWSLETTER_RECIPIENTS=

# LLM（生成洞察必填）— DeepSeek 示例（与 OpenAI 格式兼容）
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# 若用 OpenAI：
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o
