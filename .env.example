# 复制为 .env 后填写（.env 不会提交到 Git）

# 站点（GitHub Pages）
SITE_URL=https://cherrylin000.github.io/AI-news

# Buttondown（--send-buttondown，推荐）
# 本地测试先用 draft，确认后改为 send
BUTTONDOWN_API_KEY=
BUTTONDOWN_MODE=draft

# 首页订阅：把 index.html 里 YOUR_BUTTONDOWN_USERNAME 换成你的 Buttondown 用户名

# SMTP 备选（--send-newsletter）
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=AI洞察日报
SMTP_REPLY_TO=
NEWSLETTER_RECIPIENTS=

# LLM（生成洞察必填）— DeepSeek 示例（与 OpenAI 格式兼容）
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# 若用 OpenAI：
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o
